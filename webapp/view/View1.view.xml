<mvc:View controllerName="fiori.fundamentos.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{dados>/tituloPagina}">
        <content>
            <List items="{dados>/employees}"
                  itemPress="aoPressionarFuncionario"
            >
                <items>
                    <StandardListItem title="{dados>name}" description="{dados>id}"
                    type="Active" />
                </items>
            </List>
        </content>
    </Page>
</mvc:View>