<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:l="sap.ui.layout"
	xmlns:f="sap.ui.layout.form"
	xmlns:core="sap.ui.core">
	<VBox class="sapUiSmallMargin">
		<f:SimpleForm id="SimpleFormDisplay354"
			editable="false"
			layout="ResponsiveGridLayout"
			title="Dados do Funcionario"
			labelSpanXL="3"
			labelSpanL="3"
			labelSpanM="3"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="4"
			emptySpanL="4"
			emptySpanM="4"
			emptySpanS="0"
			columnsXL="1"
			columnsL="1"
			columnsM="1"
			singleContainerFullSize="false" >
            <f:content>
				<Label text="Name" />
				<Text id="nameText" text="{dados>name}" />
				<Label text="Cargo" />
				<Text id="posText" text="{dados>position}" />
				<Label text="Departamento" />
				<Text id="deptText" text="{dados>department}" />
				<Label text="Email" />
				<Text id="emailText" text="{dados>email}" />
				<Label text="Telefone" />
				<Text id="phoneText" text="{dados>phone}" />
			</f:content>
		</f:SimpleForm>
	</VBox>
</core:FragmentDefinition>